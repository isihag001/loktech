<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · <%= site.name %></title>
  <meta name="description" content="Loktech — AI knowledge owned by the village. Booklets, notebooks and resources.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;600;700&family=Rajdhani:wght@600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <!-- Accessibility bar: text size controls for low-vision / outdoor reading -->
  <div class="a11y-bar" role="region" aria-label="Accessibility controls">
    <span class="a11y-label">Text size</span>
    <button type="button" class="a11y-btn" data-text="dec" aria-label="Decrease text size">A−</button>
    <button type="button" class="a11y-btn" data-text="reset" aria-label="Reset text size">A</button>
    <button type="button" class="a11y-btn" data-text="inc" aria-label="Increase text size">A+</button>
  </div>
