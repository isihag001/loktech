<%- include('partials/head') %>
<%- include('partials/nav') %>

<main id="main">
  <section class="hero">
    <h1><%= t('home.hero.title') %></h1>
    <p class="hero-sub"><%= t('home.hero.sub') %></p>
    <p class="hero-sub-en"><%= t('home.hero.subEn') %></p>
    <div class="hero-cta">
      <a href="/learn" class="btn btn-primary"><%= t('home.cta.learn') %></a>
      <a href="/catalogue" class="btn btn-ghost"><%= t('home.cta.browse') %></a>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title"><%= t('home.sections.title') %></h2>
    <div class="section-grid">
      <% sections.forEach(function(s){ %>
        <a class="big-card" href="<%= s.href %>">
          <span class="big-card-title"><%= t(s.titleKey) %></span>
          <span class="big-card-desc"><%= t(s.descKey) %></span>
        </a>
      <% }); %>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title"><%= t('home.featured.title') %></h2>
    <div class="card-grid">
      <% featured.forEach(function(item){ %>
        <%- include('partials/resource-card', { item: item }) %>
      <% }); %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
