<%- include('partials/head') %>
<%- include('partials/nav') %>

<main id="main" class="page">
  <h1 class="page-title"><%= t('impact.title') %></h1>
  <p class="page-sub"><%= t('impact.sub') %></p>

  <section class="impact-block impact-block--good">
    <h2 class="impact-head"><%= t('impact.benefits.head') %></h2>
    <div class="impact-grid">
      <% benefits.forEach(function(b){ %>
        <div class="impact-card">
          <h3 class="impact-title"><%= t(b.titleKey) %></h3>
          <p class="impact-desc"><%= t(b.descKey) %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <section class="impact-block impact-block--bad">
    <h2 class="impact-head"><%= t('impact.harms.head') %></h2>
    <div class="impact-grid">
      <% harms.forEach(function(h){ %>
        <div class="impact-card">
          <h3 class="impact-title"><%= t(h.titleKey) %></h3>
          <p class="impact-desc"><%= t(h.descKey) %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <p class="page-note"><%- t('impact.note') %></p>
</main>

<%- include('partials/footer') %>
