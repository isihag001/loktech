<%- include('partials/head') %>
<%- include('partials/nav') %>

<main id="main" class="page">
  <h1 class="page-title"><%= t('cat.title') %></h1>
  <p class="page-sub"><%= t('cat.sub') %></p>

  <div class="filter-row" role="tablist" aria-label="Filter by type">
    <a class="chip <%= !activeType ? 'chip--on' : '' %>" href="/catalogue"><%= t('cat.filter.all') %></a>
    <% types.forEach(function(ty){ %>
      <a class="chip <%= activeType === ty.key ? 'chip--on' : '' %>" href="/catalogue?type=<%= ty.key %>">
        <%= t(ty.labelKey) %>
      </a>
    <% }); %>
  </div>

  <div class="card-grid">
    <% items.forEach(function(item){ %>
      <%- include('partials/resource-card', { item: item }) %>
    <% }); %>
  </div>

  <% if (items.length === 0) { %>
    <p class="empty"><%= t('cat.empty') %></p>
  <% } %>
</main>

<%- include('partials/footer') %>
